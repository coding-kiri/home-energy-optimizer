# Copy to terraform.tfvars.dev (gitignored via *.tfvars) and fill in.
# Use with: terraform init -upgrade -backend-config=backend-dev.hcl
#           bash bootstrap.sh terraform.tfvars.dev backend-dev.hcl
#
# Databricks auth uses ~/.databrickscfg — no token in this file.

env     = "dev"
project = "home-energy-optimizer"

aws_region = "eu-west-2"

databricks_profile = "home-energy-optimizer-dev"

# Bootstrap step 2 — filled automatically by bootstrap.sh; leave unset on first run.
# uc_master_role_arn = "arn:aws:iam::..."
# uc_external_id     = "..."
