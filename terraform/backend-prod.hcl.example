# Copy to backend-prod.hcl (gitignored) and fill in. Same bucket as dev is fine; key must differ.
#
#   terraform init -upgrade -backend-config=backend-prod.hcl
#
# If you already had local state, add -migrate-state on the first init with S3.

bucket         = "YOUR_TF_STATE_BUCKET"
key            = "home-energy-optimizer/prod/terraform.tfstate"
region         = "eu-west-2"
encrypt        = true
dynamodb_table = "YOUR_TF_LOCKS_TABLE"
